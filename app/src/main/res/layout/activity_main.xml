<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <!-- Saisie de la surface en m² -->
    <EditText
        android:id="@+id/input_surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_surface"
        android:inputType="number"
        android:autofillHints="postalAddress" />

    <!-- Saisie du nombre de pièces -->
    <EditText
        android:id="@+id/input_pieces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_pieces"
        android:inputType="number"
        android:layout_marginTop="10dp"
        android:autofillHints="postalAddress" />

    <!-- Option piscine -->
    <CheckBox
        android:id="@+id/checkbox_piscine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/checkbox_piscine"
        android:layout_marginTop="10dp" />

    <!-- Bouton pour lancer le calcul -->
    <Button
        android:id="@+id/button_calcul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/button_calcul"
        android:layout_marginTop="15dp" />

    <!-- Zone pour afficher le résultat -->
    <TextView
        android:id="@+id/result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:layout_marginTop="20dp" />

</LinearLayout>